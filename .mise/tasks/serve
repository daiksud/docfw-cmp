#!/usr/bin/env bash
#MISE description="Serve the existing static site at http://localhost:3000"

set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$repo_root"

preview_root=".local/pages"

if [[ ! -f "$preview_root/index.html" || ! -f "$preview_root/docfw-cmp/index.html" ]]; then
  printf "No local Pages preview exists. Run 'mise run build' first.\n" >&2
  exit 1
fi

exec python -m http.server "${PORT:-3000}" --bind "${HOST:-127.0.0.1}" --directory "$preview_root"

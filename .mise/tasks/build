#!/usr/bin/env bash
#MISE description="Build a GitHub Pages-equivalent docfw-cmp static site"
#MISE depends=["build-nextra", "build-vitepress"]

set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$repo_root"

./scripts/verify-doc-parity

preview_root=".local/pages"
site_root="$preview_root/docfw-cmp"

rm -rf "$preview_root"
mkdir -p "$site_root/nextra" "$site_root/vitepress"
cp -R landing/. "$site_root/"
cp -R frameworks/nextra/out/. "$site_root/nextra/"
cp -R frameworks/vitepress/.vitepress/dist/. "$site_root/vitepress/"
touch "$site_root/.nojekyll"

cat > "$preview_root/index.html" <<'HTML'
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="refresh" content="0; url=./docfw-cmp/">
    <title>docfw-cmp local preview</title>
  </head>
  <body>
    <p><a href="./docfw-cmp/">Open docfw-cmp</a></p>
  </body>
</html>
HTML
